{% assign rejection_wall = site.data.wall_of_rejection %}

{% if rejection_wall and rejection_wall.badges.size > 0 %}
  {% assign failure_cv_credit = rejection_wall.credits.failure_cv %}
  {% assign local_meme_credit = rejection_wall.credits.local_meme_reference %}
  {% assign spooder_trailer_credit = rejection_wall.credits.spooder_trailer %}
  {% assign chi26_dates_credit = rejection_wall.credits.chi26_dates %}
  {% assign uist26_dates_credit = rejection_wall.credits.uist26_dates %}
  <section class="wall-of-rejection" aria-labelledby="wall-of-rejection-title">
    <div class="wall-of-rejection-layout">
      <div class="rejection-badge-wall" aria-label="Rejection badge wall">
        <div class="rejection-badge-wall-heading">
          <div class="rejection-badge-wall-heading-copy">
            <h2 id="wall-of-rejection-title">{{ rejection_wall.section.title }}</h2>
            <p>{{ rejection_wall.section.description }}</p>
          </div>
          {% if rejection_wall.views.size > 1 %}
            <div class="rejection-wall-view-switcher" role="group" aria-label="Choose rejection badge view">
              {% for view in rejection_wall.views %}
                <button
                  class="rejection-wall-view-button{% if forloop.first %} rejection-wall-view-button-active{% endif %}"
                  type="button"
                  data-rejection-view-button
                  data-rejection-view-target="{{ view.id }}"
                  aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
                  aria-label="{{ view.aria_label | default: view.label }}"
                  title="{{ view.label }}"
                >
                  {% case view.icon %}
                    {% when 'star' %}
                      <i class="fa-solid fa-star" aria-hidden="true"></i>
                    {% when 'layer-group' %}
                      <i class="fa-solid fa-layer-group" aria-hidden="true"></i>
                    {% when 'building-columns' %}
                      <i class="fa-solid fa-building-columns" aria-hidden="true"></i>
                    {% else %}
                      <i class="fa-solid fa-table-cells-large" aria-hidden="true"></i>
                  {% endcase %}
                  <span class="sr-only">{{ view.label }}</span>
                </button>
              {% endfor %}
            </div>
          {% endif %}
        </div>
        <div class="rejection-badge-zone">
          {% for view in rejection_wall.views %}
            <div
              class="rejection-view{% if forloop.first %} rejection-view-active{% endif %}"
              data-rejection-view="{{ view.id }}"
              {% unless forloop.first %}
                hidden
              {% endunless %}
            >
              {% for group in view.groups %}
                <section class="rejection-shelf" aria-labelledby="rejection-shelf-{{ view.id }}-{{ group.id }}">
                  <div class="rejection-shelf-heading{% if view.id == 'highlights' %} sr-only{% endif %}">
                    <h3 id="rejection-shelf-{{ view.id }}-{{ group.id }}">{{ group.label }}</h3>
                    {% if group.description %}
                      <p>{{ group.description }}</p>
                    {% endif %}
                  </div>
                  <div class="rejection-badge-grid" data-rejection-wall-grid>
                    {% for badge in rejection_wall.badges %}
                      {% if badge.shelves contains group.shelf %}
                        <button
                          class="rejection-badge rejection-badge-{{ badge.rarity }}"
                          type="button"
                          data-rejection-card
                          data-rejection-source-id="{{ badge.id }}"
                          data-rejection-tooltip="{{ badge.title }}: {{ badge.short }}"
                          aria-expanded="false"
                          aria-controls="rejection-receipt-tray"
                          aria-label="{{ badge.title }}. {{ badge.short }} Click for details."
                        >
                          <span class="rejection-badge-icon rejection-badge-icon-{{ badge.icon }}" aria-hidden="true">
                            {% case badge.icon %}
                              {% when 'heart-crack' %}
                                <i class="fa-solid fa-heart-crack"></i>
                              {% when 'paper-plane-crash' %}
                                <i class="fa-solid fa-plane-circle-xmark"></i>
                              {% when 'crossed-reviewer-pens' %}
                                <span class="rejection-crossed-pens">
                                  <i class="fa-solid fa-pen-nib"></i>
                                  <i class="fa-solid fa-pen-nib"></i>
                                </span>
                              {% when 'file-circle-xmark' %}
                                <i class="fa-solid fa-file-circle-xmark"></i>
                              {% when 'user-graduate' %}
                                <i class="fa-solid fa-user-graduate"></i>
                              {% else %}
                                <i class="fa-solid fa-circle-xmark"></i>
                            {% endcase %}
                          </span>
                          <span class="rejection-badge-summary">
                            <span class="rejection-badge-title-row">
                              <span class="rejection-badge-title">{{ badge.title }}</span>
                              <span class="rejection-badge-count">x{{ badge.count }}</span>
                            </span>
                            <span class="rejection-badge-short">{{ badge.short }}</span>
                          </span>
                        </button>
                      {% endif %}
                    {% endfor %}
                  </div>
                </section>
              {% endfor %}
            </div>
          {% endfor %}

          {% for badge in rejection_wall.badges %}
            <div class="rejection-receipt-source" hidden data-rejection-receipt-source data-rejection-source-id="{{ badge.id }}">
              <div class="rejection-badge-detail">
                <p class="rejection-badge-detail-title">
                  {{ badge.title }}
                  <span>x{{ badge.count }}</span>
                </p>
                <p class="rejection-badge-paper">{{ badge.stage }} / {{ badge.date_label }}</p>
                {% if badge.detail %}
                  <p>{{ badge.detail }}</p>
                {% endif %}
                <div class="rejection-badge-meta" aria-label="Badge metadata">
                  {% if badge.category %}
                    <span>{{ badge.category }}</span>
                  {% endif %}
                  {% if badge.venue %}
                    <span>{{ badge.venue }}</span>
                  {% endif %}
                  {% if badge.funder %}
                    <span>{{ badge.funder }}</span>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}

          <div
            id="rejection-receipt-tray"
            class="rejection-receipt-tray"
            data-rejection-receipt-tray
            tabindex="-1"
            aria-live="polite"
            aria-label="Selected rejection badge note"
            hidden
          ></div>
        </div>

        <p class="rejection-wall-credit">
          Inspired by
          <a href="{{ failure_cv_credit.url }}" target="_blank" rel="noopener noreferrer">{{ failure_cv_credit.label }}</a>, Sirui's
          <button
            class="rejection-meme-link"
            type="button"
            data-rejection-meme-open
            aria-haspopup="dialog"
            aria-controls="rejection-meme-viewer"
          >
            {{ local_meme_credit.label }},
          </button>
          and the
          <a href="{{ spooder_trailer_credit.url }}" target="_blank" rel="noopener noreferrer">{{ spooder_trailer_credit.label }}</a>.
        </p>
      </div>

      <aside class="rejection-xp-panel" aria-label="Failure XP joke panel">
        <div class="rejection-xp-topline">
          <a
            class="spooder-reference-thumb"
            href="{{ spooder_trailer_credit.url }}"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Open {{ spooder_trailer_credit.label }}"
          >
            <svg class="spooder-svg" viewBox="0 0 120 120" focusable="false" aria-hidden="true">
              <path class="spooder-back" d="M35 19c18-13 49-8 58 12 7 15 1 33-12 45-6 5-9 11-8 19 1 10-9 17-23 15-13-2-22-10-23-21 0-8-4-13-11-18C4 61 8 34 35 19z" />
              <path class="spooder-suit" d="M37 15c18-10 44-5 56 12 11 15 8 35-7 48-6 5-9 11-8 19 1 10-9 16-22 14-14-2-23-11-23-22 0-7-4-12-9-17C10 56 14 29 37 15z" />
              <path class="spooder-blue" d="M37 75c7 6 15 9 24 10-3 8-3 16 0 23-17-1-28-10-28-22 0-4 1-8 4-11z" />
              <path class="spooder-web" d="M27 34c18 6 38 7 61 3M23 51c20-3 42-1 64 4M31 68c13-8 27-14 44-18M45 23c-3 24-1 45 7 65M64 18c-6 25-6 49 0 71M82 28c-13 17-24 35-32 55" />
              <path class="spooder-eye" d="M23 43c7-11 22-12 30-4-7 10-21 13-30 4z" />
              <path class="spooder-eye" d="M67 41c7-9 18-8 24 1-6 8-18 9-24-1z" />
              <path class="spooder-pupil" d="M43 41l7 1M82 41l7 1" />
              <path class="spooder-mouth" d="M47 59c9 5 21 5 31 0" />
              <path class="spooder-mark-body" d="M61 68c4 4 7 7 10 12-5-2-9-2-13 1-4-3-8-3-13-1 3-5 6-8 10-12l-4-6 7 3 7-3-4 6z" />
            </svg>
          </a>
          <div>
            <p class="rejection-wall-kicker">{{ rejection_wall.xp.kicker }}</p>
            <h3>{{ rejection_wall.xp.label }}</h3>
            <p>{{ rejection_wall.xp.blurb }}</p>
          </div>
        </div>

        <div class="failure-xp-heading">
          <div>
            <span class="failure-xp-mobile-label">{{ rejection_wall.xp.kicker }} / {{ rejection_wall.xp.label }}</span>
            <span class="failure-level-label">Level {{ rejection_wall.xp.level }}</span>
            <span class="failure-xp-count" aria-label="{{ rejection_wall.xp.current }} out of {{ rejection_wall.xp.next_level }} XP">
              <span class="failure-xp-count-current">{{ rejection_wall.xp.current }}</span>
              <span class="failure-xp-count-separator">/</span>
              <span class="failure-xp-count-next">{{ rejection_wall.xp.next_level }}</span>
              <span class="failure-xp-count-unit">XP</span>
            </span>
          </div>
          <details class="failure-xp-rules">
            <summary aria-label="Show XP rules">
              <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
            </summary>
            <div class="failure-xp-rules-panel">
              <p>{{ rejection_wall.xp.source_note }}</p>
              <ul>
                {% for rule in rejection_wall.xp.rules %}
                  <li>
                    <span>{{ rule.label }}</span>
                    <strong>{{ rule.value }}</strong>
                    {% if rule.note %}
                      <small>{{ rule.note }}</small>
                    {% endif %}
                  </li>
                {% endfor %}
              </ul>
              <div class="failure-xp-history-block">
                <span>XP over time</span>
                <svg
                  class="failure-xp-history"
                  viewBox="0 0 124 88"
                  role="img"
                  aria-label="Failure XP rose from 0 in 2021 to {{ rejection_wall.xp.current }} across the recorded rejection timeline"
                >
                  {% assign xp_points = '' %}
                  {% for point in rejection_wall.xp.timeline %}
                    {% assign point_x = point.x | times: 1.08 | plus: 8 %}
                    {% capture xp_points %}{{ xp_points }} {{ point_x }},{{ point.y }}{% endcapture %}
                  {% endfor %}
                  <line class="failure-xp-axis" x1="8" y1="68" x2="116" y2="68" />
                  <polyline points="{{ xp_points | strip }}" />
                  {% for point in rejection_wall.xp.timeline %}
                    {% assign point_x = point.x | times: 1.08 | plus: 8 %}
                    {% assign label_x = point_x %}
                    {% assign label_anchor = 'middle' %}
                    {% if forloop.first %}
                      {% assign label_anchor = 'start' %}
                    {% elsif forloop.last %}
                      {% assign label_x = point_x | minus: 4 %}
                      {% assign label_anchor = 'start' %}
                    {% else %}
                      {% assign label_x = point_x | minus: 3 %}
                      {% assign label_anchor = 'end' %}
                    {% endif %}
                    <g
                      class="failure-xp-point"
                      tabindex="0"
                      role="listitem"
                      aria-label="{{ point.date }}: {{ point.total }} XP, {{ point.label }}"
                    >
                      <title>{{ point.date }} / {{ point.total }} XP / {{ point.label }}</title>
                      <circle cx="{{ point_x }}" cy="{{ point.y }}" r="3.2" />
                      <text
                        x="{{ label_x }}"
                        y="80"
                        text-anchor="{{ label_anchor }}"
                      >
                        {{ point.axis_label | default: point.display_date | default: point.date }}
                      </text>
                    </g>
                  {% endfor %}
                </svg>
                <ol class="failure-xp-timeline">
                  {% for point in rejection_wall.xp.timeline %}
                    <li>
                      <span>{{ point.display_date | default: point.date }}</span>
                      <strong>{{ point.total }} XP</strong>
                      <em>{{ point.label }}</em>
                    </li>
                  {% endfor %}
                </ol>
              </div>
            </div>
          </details>
        </div>

        <div
          class="failure-xp-track"
          role="meter"
          aria-label="{{ rejection_wall.xp.label }} progress"
          aria-valuemin="0"
          aria-valuemax="{{ rejection_wall.xp.next_level }}"
          aria-valuenow="{{ rejection_wall.xp.current }}"
        >
          <span style="width: {{ rejection_wall.xp.progress }}%"></span>
        </div>

        {% for view in rejection_wall.views %}
          {% assign view_ledger = rejection_wall.xp.view_ledgers[view.id] %}
          {% if view_ledger %}
            <div
              class="rejection-xp-ledger{% if forloop.first %} rejection-xp-ledger-active{% endif %}"
              aria-label="{{ view.label }} failure ledger"
              data-rejection-ledger="{{ view.id }}"
              {% unless forloop.first %}
                hidden
              {% endunless %}
            >
              {% for ledger_item in view_ledger %}
                <span class="rejection-xp-ledger-item">
                  <em>{{ ledger_item.label }}</em>
                  <strong>{{ ledger_item.value }}</strong>
                  {% if ledger_item.secondary %}
                    <small>{{ ledger_item.secondary }}</small>
                  {% endif %}
                </span>
              {% endfor %}
            </div>
          {% endif %}
        {% else %}
          <div class="rejection-xp-ledger rejection-xp-ledger-active" aria-label="Failure ledger">
            {% for ledger_item in rejection_wall.xp.ledger %}
              <span class="rejection-xp-ledger-item">
                <em>{{ ledger_item.label }}</em>
                <strong>{{ ledger_item.value }}</strong>
              </span>
            {% endfor %}
          </div>
        {% endfor %}

        <blockquote class="spooder-quote">"{{ rejection_wall.xp.quote }}"</blockquote>
      </aside>
    </div>
  </section>

  <div
    id="rejection-meme-viewer"
    class="rejection-meme-viewer"
    role="dialog"
    aria-modal="true"
    aria-labelledby="rejection-meme-viewer-title"
    data-rejection-meme-viewer
    hidden
  >
    <div class="rejection-meme-viewer-backdrop" data-rejection-meme-close></div>
    <figure class="rejection-meme-viewer-frame">
      <button class="rejection-meme-viewer-close" type="button" data-rejection-meme-close aria-label="Close image viewer">
        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
      </button>
      <img src="{{ local_meme_credit.url | relative_url }}" alt="{{ local_meme_credit.label }}">
      <figcaption id="rejection-meme-viewer-title">{{ local_meme_credit.label }}</figcaption>
    </figure>
  </div>
{% endif %}
