{% assign publication_lens = site.data.publication_lens %}

{% if publication_lens and publication_lens.papers %}
  {% assign total_papers = 0 %}
  {% assign total_citations = 0 %}
  {% assign first_author_papers = 0 %}
  {% assign first_author_citations = 0 %}
  {% assign full_papers = 0 %}
  {% assign short_papers = 0 %}
  {% assign max_year_citations = 0 %}

  {% for paper in publication_lens.papers %}
    {% assign paper_data = paper[1] %}
    {% assign paper_citations = paper_data.citation_total | default: 0 %}
    {% assign paper_group = paper_data.work_group | default: paper_data.work_type %}
    {% assign total_papers = total_papers | plus: 1 %}
    {% assign total_citations = total_citations | plus: paper_citations %}
    {% if paper_data.role == 'first-author' or paper_data.role == 'co-first' %}
      {% assign first_author_papers = first_author_papers | plus: 1 %}
      {% assign first_author_citations = first_author_citations | plus: paper_citations %}
    {% endif %}
    {% if paper_group == 'short-form' %}
      {% assign short_papers = short_papers | plus: 1 %}
    {% else %}
      {% assign full_papers = full_papers | plus: 1 %}
    {% endif %}
  {% endfor %}

  {% for year_bucket in publication_lens.citation_years %}
    {% if year_bucket.total > max_year_citations %}
      {% assign max_year_citations = year_bucket.total %}
    {% endif %}
  {% endfor %}

  <aside
    class="publication-scholar-lens"
    data-scholar-lens
    data-last-synced="{{ publication_lens.metadata.last_synced }}"
    aria-labelledby="scholar-lens-title"
  >
    <div class="scholar-lens-card">
      <div class="scholar-lens-heading">
        <div>
          <p class="scholar-lens-kicker">Scholar Lens</p>
          <h2 id="scholar-lens-title">Quick publication lens</h2>
        </div>
        <a
          href="{{ publication_lens.metadata.scholar_profile }}"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open Google Scholar profile"
        >
          <i class="ai ai-google-scholar" aria-hidden="true"></i>
        </a>
      </div>

      <p class="scholar-lens-sync">
        Filter the list by authorship or paper format. Citation data synced {{ publication_lens.metadata.last_synced | date: '%b %-d, %Y' }}.
      </p>

      <div class="scholar-lens-controls" aria-label="Publication lens filters">
        <fieldset class="scholar-lens-control-group">
          <legend>Authorship</legend>
          <label>
            <input type="radio" name="publication-role-filter" value="all" checked>
            <span>All</span>
          </label>
          <label>
            <input type="radio" name="publication-role-filter" value="first-author">
            <span>First author</span>
          </label>
          <label>
            <input type="radio" name="publication-role-filter" value="coauthor">
            <span>Coauthor</span>
          </label>
        </fieldset>

        <fieldset class="scholar-lens-control-group scholar-lens-control-group-compact">
          <legend>Format</legend>
          <label>
            <input type="radio" name="publication-type-filter" value="all" checked data-scholar-type-filter>
            <span>All work</span>
          </label>
          <label>
            <input type="radio" name="publication-type-filter" value="full-paper" data-scholar-type-filter>
            <span>Full papers</span>
          </label>
          <label>
            <input type="radio" name="publication-type-filter" value="short-form" data-scholar-type-filter>
            <span>Short forms</span>
          </label>
        </fieldset>
      </div>

      <dl class="scholar-lens-stats">
        <div>
          <dt>Papers</dt>
          <dd>
            <span data-scholar-stat="papers">{{ total_papers }}</span>
            <small>of {{ total_papers }}</small>
          </dd>
        </div>
        <div>
          <dt>Citations</dt>
          <dd>
            <span data-scholar-stat="citations">{{ total_citations }}</span>
            <small>of {{ total_citations }}</small>
          </dd>
        </div>
        <div>
          <dt>First author</dt>
          <dd>
            <span data-scholar-stat="first-author">{{ first_author_papers }}</span>
            <small data-scholar-stat="first-author-citations">{{ first_author_citations }} cites</small>
          </dd>
        </div>
        <div>
          <dt>Full / Short</dt>
          <dd>
            <span data-scholar-stat="types">{{ full_papers }} / {{ short_papers }}</span>
          </dd>
        </div>
      </dl>

      <div class="scholar-lens-year-chart" aria-label="Citations by year">
        <div class="scholar-lens-chart-heading">
          <span>Cited by year</span>
          <span data-scholar-active-year>All papers</span>
        </div>
        <div class="scholar-lens-year-bars" data-scholar-year-bars>
          {% for year_bucket in publication_lens.citation_years %}
            {% assign year_ratio = 0 %}
            {% if max_year_citations > 0 %}
              {% assign year_ratio = year_bucket.total | times: 100.0 | divided_by: max_year_citations %}
            {% endif %}
            {% capture contribution_pairs -%}
              {%- for contribution in year_bucket.papers -%}
                {{ contribution.key }}:{{ contribution.citations }}{% unless forloop.last %};{% endunless %}
              {%- endfor -%}
            {%- endcapture %}
            <button
              class="scholar-lens-year-bar"
              type="button"
              data-scholar-year-bar
              data-year="{{ year_bucket.year }}"
              data-year-total="{{ year_bucket.total }}"
              data-year-papers="{{ contribution_pairs | strip }}"
              style="--year-ratio: {{ year_ratio }}%;"
              aria-label="{{ year_bucket.year }}: {{ year_bucket.total }} citations"
            >
              <span class="scholar-lens-year-count" data-year-total-label>{{ year_bucket.total }}</span>
              <span class="scholar-lens-year-track">
                <span class="scholar-lens-year-fill"></span>
                <span class="scholar-lens-year-share" data-year-paper-share aria-hidden="true"></span>
              </span>
              <span class="scholar-lens-year-label">{{ year_bucket.year }}</span>
            </button>
          {% endfor %}
        </div>
      </div>

      <p class="scholar-lens-note" data-scholar-year-note>{{ publication_lens.metadata.yearly_note }}</p>
    </div>
  </aside>
{% endif %}
