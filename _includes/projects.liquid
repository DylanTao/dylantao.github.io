{% assign project_status_label = project.status | default: '' %}
{% if project_status_label == 'Published' or project_status_label == 'Accepted' %}
  {% assign project_status_label = '' %}
{% endif %}

{% assign project_media_classes = 'project-card-media' %}
{% if project.card_image_fit == 'cover' %}
  {% assign project_media_classes = project_media_classes | append: ' project-card-media-cover' %}
{% endif %}
{% if project.redirect %}
  {% assign project_href = project.redirect %}
  {% assign project_cta_label = 'Visit project site' %}
  {% assign project_cta_icon = 'fa-arrow-up-right-from-square' %}
{% else %}
  {% assign project_href = project.url | relative_url %}
  {% assign project_cta_label = 'Read project page' %}
  {% assign project_cta_icon = 'fa-arrow-right' %}
{% endif %}
{% assign project_card_id = project.title | slugify | prepend: 'project-card-' %}
{% assign project_file_slug = project.slug
  | default: project.name
  | default: project.path
  | default: project.title
  | split: '/'
  | last
  | replace: '.md', ''
  | slugify
%}
{% assign project_card_data = site.data.project_cards[project_file_slug] %}
{% assign project_card_image_sizes = '250px' %}
{% if page.project_cards_interactive %}
  {% assign project_card_image_sizes = '(min-width: 992px) 32vw, (min-width: 768px) 45vw, 92vw' %}
{% endif %}
{% capture project_card_figure_markup %}
  {% if project.img %}
    {% if project_card_data.mobile_teaser %}
      {% assign project_img_path = project.img
        | remove: '.jpg'
        | remove: '.jpeg'
        | remove: '.png'
        | remove: '.tiff'
        | remove: '.gif'
      %}
      {% assign project_img_parts = project.img | split: '.' %}
      {% assign project_img_ext = project_img_parts.last %}
      <figure>
        <picture>
          <source
            media="(max-width: 767px)"
            srcset="{{ project_card_data.mobile_teaser | relative_url }}"
            type="image/png"
            data-project-card-mobile-teaser
          >
          {% if site.imagemagick.enabled %}
            {% unless project.card_avoid_scaling %}
              <source
                class="responsive-img-srcset"
                {% if project_img_ext == 'gif'
                  or project_img_ext == 'jpeg'
                  or project_img_ext == 'jpg'
                  or project_img_ext == 'png'
                  or project_img_ext == 'tiff'
                %}
                  srcset="{% for width in site.imagemagick.widths %}{{ project_img_path | relative_url }}-{{ width }}.webp {{ width }}w,{% endfor %}"
                  type="image/webp"
                {% else %}
                  srcset="{{ project.img | relative_url }}"
                {% endif %}
                sizes="{{ project_card_image_sizes }}"
              >
            {% endunless %}
          {% endif %}
          <img
            src="{{ project.img | relative_url }}"
            class="card-img-top project-card-img"
            width="100%"
            height="auto"
            alt="{{ project_card_data.teaser_alt | default: project.title | escape }}"
            loading="eager"
            onerror="this.onerror=null; document.querySelectorAll('.responsive-img-srcset').forEach(function (n) { n.remove(); });"
          >
        </picture>
      </figure>
    {% elsif page.project_cards_interactive %}
      {% assign project_teaser_alt = project_card_data.teaser_alt | default: project.title %}
      {% include figure.liquid loading="eager" path=project.img sizes="(min-width: 992px) 32vw, (min-width: 768px) 45vw, 92vw" alt=project_teaser_alt class="card-img-top project-card-img" avoid_scaling=project.card_avoid_scaling %}
    {% else %}
      {% include figure.liquid loading="eager" path=project.img sizes="250px" alt="project thumbnail" class="card-img-top project-card-img" avoid_scaling=project.card_avoid_scaling %}
    {% endif %}
  {% endif %}
{% endcapture %}
{% capture project_random_teaser_paths %}
  {% if project_card_data.teasers %}
    {% for teaser in project_card_data.teasers %}
      {{ teaser | relative_url }}{% unless forloop.last %}|{% endunless %}
    {% endfor %}
  {% endif %}
{% endcapture %}
{% capture project_card_style %}
  {% if project_card_data.accents %}
    --project-accent-morning: {{ project_card_data.accents.morning | default: 'var(--global-theme-color)' }};
    --project-accent-noon: {{ project_card_data.accents.noon | default: 'var(--global-theme-color)' }};
    --project-accent-afternoon: {{ project_card_data.accents.afternoon | default: 'var(--global-theme-color)' }};
    --project-accent-evening: {{ project_card_data.accents.evening | default: 'var(--global-theme-color)' }};
  {% endif %}
{% endcapture %}

{% if page.project_cards_interactive %}
  <article
    class="project-card"
    data-project-card
    {% if project_card_data.accents %}
      style="{{ project_card_style | strip_newlines | strip }}"
    {% endif %}
  >
    <div class="card h-100 hoverable">
      <div class="project-card-preview">
        {% if project.img %}
          <div
            class="{{ project_media_classes }}"
            {% if project_card_data.teasers %}
              data-random-teaser data-random-teasers="{{ project_random_teaser_paths | strip }}"
            {% endif %}
            {% if project.image_aspect %}
              style="
                --project-image-aspect: {{ project.image_aspect }};
                {% if project.card_image_position %}--project-image-position: {{ project.card_image_position }};{% endif %}
              "
            {% endif %}
          >
            {{ project_card_figure_markup }}
          </div>
        {% endif %}
        <div class="card-body project-card-body">
          <div class="project-card-heading{% if project_card_data.icon %} project-card-heading--with-icon{% endif %}">
            {% include project_card_icon.liquid icon=project_card_data.icon %}
            {% if include.heading_level == 4 %}
              <h4 class="card-title">{{ project.title }}</h4>
            {% else %}
              <h3 class="card-title">{{ project.title }}</h3>
            {% endif %}
          </div>
          {% if project.venue or project.year or project.role or project_status_label != '' %}
            <p class="project-card-meta">
              {% if project.venue %}
                <span>{{ project.venue }}</span>
              {% elsif project.year %}
                <span>{{ project.year }}</span>
              {% endif %}
              {% if project.role %}
                <span>{{ project.role }}</span>
              {% endif %}
              {% if project_status_label != '' %}
                <span>{{ project_status_label }}</span>
              {% endif %}
            </p>
          {% endif %}
          <p class="card-text">{{ project.description }}</p>
          {% if project_card_data.origin_line %}
            <div class="project-card-story" data-project-card-story>
              <div class="project-card-story-beat" data-project-card-origin>
                <p class="project-card-story-label">Why it began</p>
                <p>{{ project_card_data.origin_line }}</p>
              </div>
              {% if project_card_data.evolution_line %}
                <div class="project-card-story-beat" data-project-card-evolution>
                  <p class="project-card-story-label">What changed</p>
                  <p>{{ project_card_data.evolution_line }}</p>
                </div>
              {% endif %}
            </div>
          {% endif %}
          <span class="project-card-preview-affordance" aria-hidden="true">
            <i class="fa-solid fa-plus"></i>
          </span>
          {% if project_card_data.takeaways %}
            <div class="project-card-takeaways" aria-label="{{ project.title }} takeaways">
              <p class="project-card-takeaways-label">What to notice</p>
              <ul>
                {% for takeaway in project_card_data.takeaways limit: 2 %}
                  <li>{{ takeaway }}</li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}
        </div>
        <button
          class="project-card-trigger"
          type="button"
          data-project-card-trigger
          aria-expanded="false"
          aria-controls="{{ project_card_id }}-panel"
          aria-label="Preview {{ project.title }}"
        ></button>
      </div>

      <div class="project-card-panel" id="{{ project_card_id }}-panel" data-project-card-panel hidden>
        <div class="project-card-actions project-card-actions-expanded">
          <a
            class="project-card-open-link"
            href="{{ project_href }}"
            data-project-card-primary-action
            {% if project.redirect %}
              target="_blank" rel="noopener noreferrer"
            {% endif %}
          >
            <span>{{ project_cta_label }}</span>
            <i class="fa-solid {{ project_cta_icon }}" aria-hidden="true"></i>
          </a>
          {% if project.github %}
            <a
              class="project-card-action-link project-card-secondary-link"
              href="{{ project.github }}"
              target="_blank"
              rel="noopener noreferrer"
              data-toggle="tooltip"
              title="Code Repository"
            >
              <i class="fa-brands fa-github gh-icon" aria-hidden="true"></i>
              <span>Code</span>
            </a>
            {% if project.github_stars %}
              <span class="stars" data-toggle="tooltip" title="GitHub Stars">
                <i class="fa-solid fa-star"></i>
                <span id="{{ project.github_stars }}-stars"></span>
              </span>
            {% endif %}
          {% endif %}
        </div>
        <button class="project-card-close" type="button" data-project-card-close aria-label="Close {{ project.title }} preview">
          <i class="fa-solid fa-xmark" aria-hidden="true"></i>
        </button>
      </div>
    </div>
  </article>
{% else %}
  <div class="col">
    <div class="card h-100 hoverable">
      <a
        class="project-card-link"
        href="{{ project_href }}"
        {% if project.redirect %}
          target="_blank" rel="noopener noreferrer"
        {% endif %}
      >
        {% if project.img %}
          <div
            class="{{ project_media_classes }}"
            {% if project_card_data.teasers %}
              data-random-teaser data-random-teasers="{{ project_random_teaser_paths | strip }}"
            {% endif %}
            {% if project.image_aspect %}
              style="
                --project-image-aspect: {{ project.image_aspect }};
                {% if project.card_image_position %}--project-image-position: {{ project.card_image_position }};{% endif %}
              "
            {% endif %}
          >
            {{ project_card_figure_markup }}
          </div>
        {% endif %}
        <div class="card-body">
          <h2 class="card-title">{{ project.title }}</h2>
          {% if project.venue or project.year or project.role or project_status_label != '' %}
            <p class="project-card-meta">
              {% if project.venue %}
                <span>{{ project.venue }}</span>
              {% elsif project.year %}
                <span>{{ project.year }}</span>
              {% endif %}
              {% if project.role %}
                <span>{{ project.role }}</span>
              {% endif %}
              {% if project_status_label != '' %}
                <span>{{ project_status_label }}</span>
              {% endif %}
            </p>
          {% endif %}
          <p class="card-text">{{ project.description }}</p>
        </div>
      </a>
      {% if project.github %}
        <div class="project-card-actions">
          <a
            class="project-card-action-link"
            href="{{ project.github }}"
            target="_blank"
            rel="noopener noreferrer"
            data-toggle="tooltip"
            title="Code Repository"
          >
            <i class="fa-brands fa-github gh-icon" aria-hidden="true"></i>
            <span class="sr-only">Code Repository</span>
          </a>
          {% if project.github_stars %}
            <span class="stars" data-toggle="tooltip" title="GitHub Stars">
              <i class="fa-solid fa-star"></i>
              <span id="{{ project.github_stars }}-stars"></span>
            </span>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
{% endif %}
