<div class="col mb-4">
  <a
    class="project-card-link"
    href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}"
    {% if project.redirect %}
      target="_blank" rel="noopener noreferrer"
    {% endif %}
  >
    <div class="card h-100 hoverable">
      <div class="row no-gutters">
        {% if project.img %}
          <div class="col-md-6">
            <div
              class="project-card-media project-card-media-horizontal"
              {% if project.image_aspect %}
                style="--project-image-aspect: {{ project.image_aspect }};"
              {% endif %}
            >
              {% include figure.liquid loading="eager" path=project.img sizes="(min-width: 768px) 156px, 50vw" alt="project thumbnail" class="card-img project-card-img" %}
            </div>
          </div>
        {% endif %}
        <div class="{% if project.img %}col-md-6{% else %}col-md-12{% endif %}">
          <div class="card-body">
            <h3 class="card-title">{{ project.title }}</h3>
            {% if project.venue or project.year or project.role or project.status %}
              <p class="project-card-meta">
                {% if project.venue %}
                  <span>{{ project.venue }}</span>
                {% elsif project.year %}
                  <span>{{ project.year }}</span>
                {% endif %}
                {% if project.role %}
                  <span>{{ project.role }}</span>
                {% endif %}
                {% if project.status %}
                  <span>{{ project.status }}</span>
                {% endif %}
              </p>
            {% endif %}
            <p class="card-text">{{ project.description }}</p>
            <div class="row ml-1 mr-1 p-0">
              {% if project.github %}
                <div class="github-icon">
                  <div class="icon" data-toggle="tooltip" title="Code Repository">
                    <a href="{{ project.github }}"><i class="fa-brands fa-github gh-icon"></i></a>
                  </div>
                  {% if project.github_stars %}
                    <span class="stars" data-toggle="tooltip" title="GitHub Stars">
                      <i class="fa-solid fa-star"></i>
                      <span id="{{ project.github_stars }}-stars"></span>
                    </span>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </a>
</div>
