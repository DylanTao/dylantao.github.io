<header>
  <!-- Nav Bar -->
  <nav id="navbar" class="navbar navbar-light navbar-expand-md {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}" role="navigation">
    <div class="container panel-shell">
      {% assign brand_name = site.first_name | append: ' ' | append: site.last_name | strip %}
      <a class="navbar-brand title site-brand" href="{{ '/' | relative_url }}" aria-label="{{ brand_name }} home">
        <span class="site-brand-mark" aria-hidden="true">
          {{- site.first_name | slice: 0 -}}
          {{- site.last_name | slice: 0 -}}
        </span>
        <span class="site-brand-name">{{ brand_name }}</span>
      </a>
      <!-- Navbar Toggle -->
      <button
        class="navbar-toggler collapsed ml-auto"
        type="button"
        data-toggle="collapse"
        data-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>

      <div class="collapse navbar-collapse text-right" id="navbarNav">
        <ul class="navbar-nav ml-auto flex-nowrap">
          {% for page in site.pages %}
            {% if page.permalink == '/' %} {% assign about_title = page.title %} {% endif %}
          {% endfor %}

          <!-- About -->
          <li class="nav-item {% if page.permalink == '/' %}active{% endif %}">
            <a class="nav-link" href="{{ '/' | relative_url }}">
              {{- about_title }}
              {% if page.permalink == '/' %}
                <span class="sr-only">(current)</span>
              {% endif %}
            </a>
          </li>

          <!-- Other pages -->
          {% assign sorted_pages = site.pages | sort: 'nav_order' %}
          {% for p in sorted_pages %}
            {% if p.nav and p.autogen == null %}
              {% if p.dropdown %}
                {% assign has_active_child = false %}
                {% for child in p.children %}
                  {% if page.title == child.title %}
                    {% assign has_active_child = true %}
                  {% endif %}
                {% endfor %}
                <li class="nav-item dropdown {% if page.title == p.title or has_active_child %}active{% endif %}">
                  <a
                    class="nav-link dropdown-toggle"
                    href="#"
                    id="navbarDropdown"
                    role="button"
                    data-toggle="dropdown"
                    aria-haspopup="true"
                    aria-expanded="false"
                  >
                    {{- p.title }}
                    {% if page.title == p.title or has_active_child %}
                      <span class="sr-only">(current)</span>
                    {% endif %}
                  </a>
                  <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                    {% for child in p.children %}
                      {% if child.title == 'divider' %}
                        <div class="dropdown-divider"></div>
                      {% else %}
                        <a
                          class="dropdown-item {% if page.title == child.title %}active{% endif %}"
                          href="{% if child.permalink contains '://' %}{{ child.permalink }}{% else %}{{ child.permalink | relative_url }}{% endif %}"
                        >
                          {{- child.title -}}
                        </a>
                      {% endif %}
                    {% endfor %}
                  </div>
                </li>
              {% else %}
                {% assign parent_link = p.permalink | remove: 'index.html' %}
                <li class="nav-item {% if page.url contains parent_link %}active{% endif %}">
                  {%- if p.permalink contains '://' -%}
                    {%- assign url = p.permalink -%}
                  {%- elsif p.permalink contains '/blog/' -%}
                    {%- assign url = '/blog/' -%}
                  {%- else -%}
                    {%- assign url = p.url -%}
                  {%- endif %}
                  <a class="nav-link" href="{{ url | relative_url }}">
                    {{- p.title }}
                    {% if page.url contains p.url %}
                      <span class="sr-only">(current)</span>
                    {% endif %}
                  </a>
                </li>
              {% endif %}
            {% endif %}
          {% endfor %}
          {% if site.search_enabled %}
            <!-- Search -->
            <li class="nav-item">
              <button id="search-toggle" type="button" title="Search (Ctrl K)" aria-label="Search" onclick="openSearchModal()">
                <span class="nav-link nav-control-link"><i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i></span>
              </button>
            </li>
          {% endif %}
          {% if site.enable_darkmode %}
            <!-- Theme mode -->
            <li class="toggle-container theme-mode-container">
              <button
                id="theme-toggle"
                type="button"
                title="Change theme"
                aria-label="Change theme"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-controls="theme-menu"
              >
                <span class="theme-toggle-icon" id="theme-toggle-icon" aria-hidden="true">
                  <i class="fa-solid fa-cloud-sun"></i>
                </span>
                <span class="sr-only" id="theme-toggle-label">Morning theme</span>
              </button>
              <div class="theme-menu" id="theme-menu" role="listbox" aria-label="Theme mode" hidden>
                <button class="theme-option" type="button" role="option" data-theme-mode-option="morning" aria-selected="false">
                  <i class="fa-solid fa-cloud-sun" aria-hidden="true"></i>
                  <span>Morning</span>
                </button>
                <button class="theme-option" type="button" role="option" data-theme-mode-option="noon" aria-selected="false">
                  <i class="fa-solid fa-sun" aria-hidden="true"></i>
                  <span>Noon</span>
                </button>
                <button class="theme-option" type="button" role="option" data-theme-mode-option="afternoon" aria-selected="false">
                  <i class="fa-solid fa-cloud-sun-rain" aria-hidden="true"></i>
                  <span>Afternoon</span>
                </button>
                <button class="theme-option" type="button" role="option" data-theme-mode-option="evening" aria-selected="false">
                  <i class="fa-solid fa-moon" aria-hidden="true"></i>
                  <span>Evening</span>
                </button>
              </div>
            </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>
  {% if site.enable_progressbar %}
    <!-- Scrolling Progress Bar -->
    <progress id="progress" value="0">
      <div class="progress-container">
        <span class="progress-bar"></span>
      </div>
    </progress>
  {% endif %}
</header>
