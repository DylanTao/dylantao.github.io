<header>
  <!-- Nav Bar -->
  <nav
    id="navbar"
    class="navbar navbar-light navbar-expand-md {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}"
    aria-label="{% if page.ai_profile %}AI profile navigation{% else %}Primary navigation{% endif %}"
  >
    <div class="container panel-shell">
      {% assign brand_name = site.first_name | append: ' ' | append: site.last_name | strip %}
      {% assign brand_first_initial = site.first_name | slice: 0 %}
      {% assign brand_last_initial = site.last_name | slice: 0 %}
      {% assign brand_initials = brand_first_initial | append: brand_last_initial %}
      {% assign brand_href = '/' | relative_url %}
      {% if page.ai_profile %}
        {% capture brand_href %}{{ '/ai/' | relative_url }}#identity{% endcapture %}
      {% endif %}
      <a
        class="navbar-brand title site-brand"
        href="{{ brand_href }}"
        aria-label="{{ brand_name }}{% if page.ai_profile %} AI profile{% else %} home{% endif %}"
      >
        {% include brand-orange.liquid initials=brand_initials %}
        <span class="site-brand-name">{{ brand_name }}</span>
      </a>
      <div class="navbar-actions" role="group" aria-label="Site actions">
        {% include site_format_switch.liquid %}
        {% if site.search_enabled %}
          <button id="search-toggle" type="button" title="Search (Ctrl K)" aria-label="Search" onclick="openSearchModal()">
            <span class="nav-link nav-control-link"><i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i></span>
          </button>
        {% endif %}
        {% if site.enable_darkmode %}
          <div class="toggle-container theme-mode-container navbar-action">
            {% include theme_mode_control.liquid id_prefix='theme' class='theme-mode-control-nav' %}
          </div>
        {% endif %}
      </div>
      <!-- Navbar Toggle -->
      <button
        class="navbar-toggler collapsed ml-auto"
        type="button"
        data-toggle="collapse"
        data-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>

      <div class="navbar-collapse text-right" id="navbarNav">
        <ul class="navbar-nav navbar-menu-list ml-auto flex-nowrap">
          {% if page.ai_profile %}
            <li class="nav-item">
              <a class="nav-link" href="{{ '/ai/' | relative_url }}#identity" data-ai-nav-link="identity">Identity</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="{{ '/ai/' | relative_url }}#research" data-ai-nav-link="research">Research</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="{{ '/ai/' | relative_url }}#publications" data-ai-nav-link="publications">Publications</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="{{ '/ai/' | relative_url }}#routes" data-ai-nav-link="routes">Routes</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="{{ '/ai/' | relative_url }}#sources" data-ai-nav-link="sources">Sources</a>
            </li>
          {% else %}
            {% for site_page in site.pages %}
              {% if site_page.permalink == '/' %} {% assign about_title = site_page.title %} {% endif %}
            {% endfor %}

            <!-- About -->
            <li class="nav-item {% if page.permalink == '/' %}active{% endif %}">
              <a class="nav-link" href="{{ '/' | relative_url }}">
                {{- about_title }}
                {% if page.permalink == '/' %}
                  <span class="sr-only">(current)</span>
                {% endif %}
              </a>
            </li>

            <!-- Other pages -->
            {% assign sorted_pages = site.pages | sort: 'nav_order' %}
            {% for p in sorted_pages %}
              {% if p.nav and p.autogen == null %}
                {% if p.dropdown %}
                  {% assign has_active_child = false %}
                  {% for child in p.children %}
                    {% if page.title == child.title %}
                      {% assign has_active_child = true %}
                    {% endif %}
                  {% endfor %}
                  <li class="nav-item dropdown {% if page.title == p.title or has_active_child %}active{% endif %}">
                    <a
                      class="nav-link dropdown-toggle"
                      href="#"
                      id="navbarDropdown"
                      role="button"
                      data-toggle="dropdown"
                      aria-haspopup="true"
                      aria-expanded="false"
                    >
                      {{- p.title }}
                      {% if page.title == p.title or has_active_child %}
                        <span class="sr-only">(current)</span>
                      {% endif %}
                    </a>
                    <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                      {% for child in p.children %}
                        {% if child.title == 'divider' %}
                          <div class="dropdown-divider"></div>
                        {% else %}
                          <a
                            class="dropdown-item {% if page.title == child.title %}active{% endif %}"
                            href="{% if child.permalink contains '://' %}{{ child.permalink }}{% else %}{{ child.permalink | relative_url }}{% endif %}"
                          >
                            {{- child.title -}}
                          </a>
                        {% endif %}
                      {% endfor %}
                    </div>
                  </li>
                {% else %}
                  {% assign parent_link = p.permalink | remove: 'index.html' %}
                  {%- if p.permalink contains '://' -%}
                    {%- assign url = p.permalink -%}
                  {%- elsif p.permalink contains '/blog/' -%}
                    {%- assign url = '/blog/' -%}
                  {%- else -%}
                    {%- assign url = p.url -%}
                  {%- endif %}
                  <li class="nav-item {% if page.url contains parent_link %}active{% endif %}">
                    <a class="nav-link" href="{{ url | relative_url }}">
                      {{- p.title }}
                      {% if page.url contains p.url %}
                        <span class="sr-only">(current)</span>
                      {% endif %}
                    </a>
                  </li>
                {% endif %}
              {% endif %}
            {% endfor %}
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>
  {% if site.enable_progressbar %}
    <!-- Scrolling Progress Bar -->
    <progress id="progress" value="0">
      <div class="progress-container">
        <span class="progress-bar"></span>
      </div>
    </progress>
  {% endif %}
</header>
