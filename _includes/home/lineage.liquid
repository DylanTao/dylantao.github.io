{% if page.lineage %}
  <div class="home-lineage" aria-labelledby="home-lineage-title">
    <h3 id="home-lineage-title">{{ page.lineage.title | default: 'Advisor Lineage & Past Collaborations' }}</h3>
    {% if page.lineage.rows %}
      <div class="home-lineage-list">
        {% for row in page.lineage.rows %}
          <div class="home-lineage-row">
            <span class="home-lineage-label">{{ row.label }}</span>
            <span class="home-lineage-people">
              {% for person in row.people %}
                <span class="home-lineage-person">
                  <a href="{{ person.url }}" target="_blank" rel="noopener noreferrer">{{ person.name }}</a>
                  {% if person.area %}
                    <span>{{ person.area }}</span>
                  {% endif %}
                </span>
              {% endfor %}
            </span>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
{% endif %}
