<section
  id="start"
  class="home-hero home-reveal"
  data-home-section="start"
  aria-labelledby="home-title"
>
  <div class="home-hero-copy">
    <p class="home-kicker">{{ page.hero.eyebrow }}</p>
    <h1 id="home-title" class="home-title">{{ page.hero.title }}</h1>
    <p class="home-lede">{{ page.hero.lede }}</p>
    {% if page.hero.affiliation_lines %}
      <p class="home-affiliation">
        {%- for line in page.hero.affiliation_lines %}
          <span>
            {%- if line.parts -%}
              {%- for part in line.parts -%}
                {%- if part.url -%}
                  <a href="{{ part.url }}" target="_blank" rel="noopener noreferrer">{{- part.text -}}</a>
                {%- else -%}
                  {{- part.text -}}
                {%- endif -%}
              {%- endfor -%}
            {%- else -%}
              {{- line.text -}}
            {%- endif -%}
          </span>
        {%- endfor %}
      </p>
    {% elsif page.hero.affiliation %}
      <p class="home-affiliation">{{ page.hero.affiliation }}</p>
    {% endif %}

    <div class="home-actions" aria-label="Primary actions">
      <a class="home-btn home-btn-primary" href="{{ page.hero.primary_cta.url | relative_url }}">
        {{ page.hero.primary_cta.label }}
        <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
      </a>
      <a class="home-btn home-btn-secondary" href="{{ page.hero.secondary_cta.url | relative_url }}">
        {{ page.hero.secondary_cta.label }}
      </a>
      <a
        class="home-btn home-btn-contact"
        href="{{ page.hero.tertiary_cta.url }}"
        {% if page.hero.tertiary_cta.external %}
          target="_blank" rel="noopener noreferrer"
        {% endif %}
      >
        {{ page.hero.tertiary_cta.label }}
      </a>
    </div>
  </div>

  <div
    class="home-hero-media"
    aria-label="Portrait and research artifacts"
    data-home-artifact-stage
  >
    <div class="home-desk-mode-switch" data-home-desk-mode-switch aria-label="Desk view mode">
      <button type="button" data-home-desk-mode="2d" aria-pressed="true">2D</button>
      <span aria-hidden="true">|</span>
      <button type="button" data-home-desk-mode="3d" aria-pressed="false">3D</button>
    </div>
    <div class="home-desk-corner-scene" data-home-desk-scene aria-hidden="true">
      <div class="home-desk-corner-fallback" aria-hidden="true"></div>
    </div>
    <div class="home-desk-control-strip" data-home-desk-controls aria-label="3D desk controls" aria-hidden="true">
      <button type="button" data-home-desk-control="previous" aria-label="Previous meme record" title="Previous meme record">
        <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
      </button>
      <button
        type="button"
        data-home-desk-control="spin"
        aria-pressed="false"
        aria-label="Spin meme record"
        title="Spin meme record"
      >
        <i class="fa-solid fa-play" data-home-desk-play-icon aria-hidden="true"></i>
        <i class="fa-solid fa-pause" data-home-desk-pause-icon aria-hidden="true"></i>
      </button>
      <button type="button" data-home-desk-control="next" aria-label="Next meme record" title="Next meme record">
        <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
      </button>
      <button type="button" data-home-desk-control="reset" aria-label="Reset 3D desk view" title="Reset 3D desk view">
        <i class="fa-solid fa-rotate-left" aria-hidden="true"></i>
      </button>
      {% if page.hero.artifacts %}
        {% for artifact in page.hero.artifacts limit: 2 %}
          {% if artifact.url %}
            <a
              href="{{ artifact.url | relative_url }}"
              {% if artifact.external %}
                target="_blank" rel="noopener noreferrer"
              {% endif %}
              data-home-desk-artifact-link
              aria-label="{{ artifact.title | escape }}"
              title="{{ artifact.title | escape }}"
            >
              <i class="fa-solid {{ artifact.icon | default: 'fa-arrow-up-right-from-square' }}" aria-hidden="true"></i>
            </a>
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>

    {% if page.profile.image %}
      {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
      {% assign meme_records = page.profile.meme_records %}
      <div
        class="home-portrait-frame{% if meme_records %} home-profile-recordable{% elsif page.profile.image_hovers %} home-profile-swappable{% endif %}"
        id="home-profile-image-container"
        tabindex="0"
        aria-label="Sirui Tao portrait meme-record preview"
        {% if meme_records %}
          data-record-images="{% for record in meme_records %}{{ record.image | prepend: '/assets/img/' | relative_url }}{% unless forloop.last %}|{% endunless %}{% endfor %}"
          data-record-titles="{% for record in meme_records %}{{ record.title | escape }}{% unless forloop.last %}|{% endunless %}{% endfor %}"
          data-record-artists="{% for record in meme_records %}{{ record.artist | escape }}{% unless forloop.last %}|{% endunless %}{% endfor %}"
          data-record-durations="{% for record in meme_records %}{{ record.duration | default: '0:18' | escape }}{% unless forloop.last %}|{% endunless %}{% endfor %}"
          data-record-tones="{% for record in meme_records %}{{ record.tone | escape }}{% unless forloop.last %}|{% endunless %}{% endfor %}"
          data-record-covers="{% for record in meme_records %}{% assign record_cover = record.cover_image | default: record.image %}{{ record_cover | prepend: '/assets/img/' | relative_url }}{% unless forloop.last %}|{% endunless %}{% endfor %}"
          data-record-sources="{% for record in meme_records %}{{ record.source_url | escape }}{% unless forloop.last %}|{% endunless %}{% endfor %}"
        {% else %}
          data-images="{% for img in page.profile.image_hovers %}{{ img | prepend: '/assets/img/' | relative_url }}{% unless forloop.last %},{% endunless %}{% endfor %}"
        {% endif %}
      >
        {% if meme_records %}
          <div class="home-record-scene" data-home-record-scene aria-hidden="true">
            <div class="home-record-scene-fallback">
              <div class="home-record-art"></div>
            </div>
          </div>
        {% endif %}
        {% include figure.liquid loading="eager" path=profile_image_path class="home-portrait-img" sizes="(min-width: 992px) 340px, 70vw" alt="Sirui Tao portrait" cache_bust=true %}
        {% if meme_records or page.profile.image_hovers %}
          <div class="home-profile-image-hover-layer" aria-hidden="true"></div>
        {% endif %}
        {% if meme_records %}
          <button
            class="home-record-play"
            type="button"
            data-home-record-play
            aria-pressed="false"
            aria-label="Spin meme-record album"
          >
            <i class="fa-solid fa-play" data-home-record-play-icon aria-hidden="true"></i>
            <i class="fa-solid fa-pause" data-home-record-pause-icon aria-hidden="true"></i>
          </button>
          <button
            class="home-record-nav home-record-nav-prev"
            type="button"
            data-home-record-prev
            aria-label="Previous meme record"
          >
            <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
          </button>
          <button
            class="home-record-nav home-record-nav-next"
            type="button"
            data-home-record-next
            aria-label="Next meme record"
          >
            <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
          </button>
        {% endif %}
      </div>

      {% if meme_records %}
        <div
          class="home-record-card-pile"
          data-home-record-pile
          aria-live="polite"
          aria-label="Dropped meme record cards"
          hidden
        ></div>
      {% endif %}
    {% endif %}

    {% if page.hero.artifacts %}
      <div class="home-artifact-stack has-coffee-stain" aria-label="Featured research artifacts">
        {% for artifact in page.hero.artifacts %}
          {% assign artifact_tone = artifact.tone | default: 'accent' %}
          {% capture artifact_card_content %}
            {% if artifact.image %}
              <div class="home-artifact-thumb" aria-hidden="true">
                {% include figure.liquid loading="eager" path=artifact.image class="home-artifact-img" sizes="(min-width: 992px) 92px, 64px" alt=artifact.title %}
              </div>
            {% else %}
              <span class="home-artifact-mark" aria-hidden="true">
                <i class="fa-solid {{ artifact.icon | default: 'fa-arrow-up-right-from-square' }}"></i>
              </span>
            {% endif %}
            <span class="home-artifact-copy">
              <span>{{ artifact.label }}</span>
              <strong>{{ artifact.title }}</strong>
              {% if artifact.meta %}
                <em>{{ artifact.meta }}</em>
              {% endif %}
            </span>
            {% if artifact.url %}
              <span class="home-artifact-route" aria-hidden="true">
                <i class="fa-solid fa-arrow-up-right-from-square"></i>
              </span>
            {% endif %}
          {% endcapture %}

          {% if artifact.url %}
            <a
              class="home-artifact-card home-artifact-card-{{ forloop.index }} home-artifact-tone-{{ artifact_tone }}"
              href="{{ artifact.url | relative_url }}"
              {% if artifact.external %}
                target="_blank" rel="noopener noreferrer"
              {% endif %}
            >
              {{ artifact_card_content }}
            </a>
          {% else %}
            <div
              class="home-artifact-card home-artifact-card-{{ forloop.index }} home-artifact-tone-{{ artifact_tone }}"
            >
              {{ artifact_card_content }}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if page.hero.inspiration_credit %}
        <p class="home-inspiration-credit">
          {% if page.hero.inspiration_credit.url %}
            <a href="{{ page.hero.inspiration_credit.url }}" target="_blank" rel="noopener noreferrer">
              {{ page.hero.inspiration_credit.label }}
            </a>
          {% else %}
            {{ page.hero.inspiration_credit.label }}
          {% endif %}
        </p>
      {% endif %}
    {% endif %}
  </div>

  {% if page.credibility %}
    <div class="home-cred-grid" aria-label="Quick facts">
      {% for item in page.credibility %}
        <div class="home-cred-item">
          <span>{{ item.label }}</span>
          {% if item.url %}
            <a
              class="home-cred-link"
              href="{{ item.url }}"
              {% if item.external %}
                target="_blank" rel="noopener noreferrer"
              {% endif %}
            >
              <strong>{{ item.value }}</strong>
            </a>
          {% else %}
            <strong>{{ item.value }}</strong>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  {% endif %}
</section>
