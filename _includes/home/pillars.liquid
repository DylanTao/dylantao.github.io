{% if page.pillars %}
  <section id="focus" class="home-section home-pillars-section home-reveal" data-home-section="focus" aria-labelledby="home-pillars-title">
    <div class="home-section-heading">
      <p class="home-kicker">Research focus</p>
      <h2 id="home-pillars-title">Where I study judgment in practice.</h2>
    </div>

    <div class="home-pillars">
      {% for pillar in page.pillars %}
        <article class="home-pillar">
          <span>{{ pillar.label }}</span>
          <h3>{{ pillar.title }}</h3>
          <p>{{ pillar.text }}</p>
        </article>
      {% endfor %}
    </div>
  </section>
{% endif %}
