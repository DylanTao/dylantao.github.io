{% if page.research_motion %}
  {% assign motion_section_id = include.section_id | default: 'focus' %}
  {% assign motion_section_key = include.section_key | default: motion_section_id %}
  <section
    id="{{ motion_section_id }}"
    class="home-section home-research-motion home-reveal"
    data-home-section="{{ motion_section_key }}"
    data-research-motion-section
    aria-labelledby="{{ motion_section_id }}-title"
  >
    <div class="home-motion-intro">
      <div class="home-section-heading">
        <p class="home-kicker">{{ page.research_motion.eyebrow }}</p>
        <h2 id="{{ motion_section_id }}-title">{{ page.research_motion.title }}</h2>
        <p>{{ page.research_motion.intro }}</p>
      </div>
    </div>

    <div class="home-motion-body">
      {% if page.research_motion.modes %}
        <div class="home-motion-controls" aria-label="Research motion modes">
          {% for mode in page.research_motion.modes %}
            <button
              class="home-motion-mode{% if forloop.first %} is-active{% endif %}"
              type="button"
              data-research-mode="{{ mode.id }}"
              aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
            >
              <span>{{ mode.label }}</span>
              <strong>{{ mode.title }}</strong>
              <small>{{ mode.text }}</small>
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="home-motion-stage" data-research-motion>
      <canvas data-research-motion-canvas aria-hidden="true"></canvas>
      {% if site.enable_darkmode %}
        {% include theme_mode_control.liquid id_prefix='motion-theme' class='home-motion-theme-control' %}
      {% endif %}
      <div class="home-motion-readout" aria-hidden="true">
        <span data-research-motion-readout>Design</span>
        <strong>Comparison as a working surface</strong>
      </div>
      <p class="sr-only" data-research-motion-status>Showing the Design motion sketch.</p>
    </div>

    {% if page.research_motion.credit %}
      <p class="home-motion-credit">
        <span class="home-motion-credit-label">Motion note</span>
        <span class="home-motion-credit-copy">
          {{- page.research_motion.credit.text }}
          <a href="{{ page.research_motion.credit.stripe_url }}">{{ page.research_motion.credit.stripe_label }}</a>
          and
          <a href="{{ page.research_motion.credit.katie_url }}">{{ page.research_motion.credit.katie_label }}</a>.
        </span>
      </p>
    {% endif %}

    {% if page.research_motion.modes %}
      <div class="home-motion-details" aria-live="polite">
        {% for mode in page.research_motion.modes %}
          <article
            class="home-motion-detail{% if forloop.first %} is-active{% endif %}"
            data-research-detail="{{ mode.id }}"
            {% unless forloop.first %}
              hidden
            {% endunless %}
          >
            <div class="home-motion-detail-main">
              <span class="home-motion-detail-label">{{ mode.label }} lens</span>
              <h3>{{ mode.detail_title | default: mode.title }}</h3>
              <p>{{ mode.detail_text | default: mode.text }}</p>
              {% if mode.link_url %}
                <a class="home-motion-detail-link" href="{{ mode.link_url | relative_url }}">
                  {{ mode.link_label | default: 'Learn more' }}
                  <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
                </a>
              {% endif %}
            </div>
            {% if mode.detail_points %}
              <div class="home-motion-detail-rail">
                <span class="home-motion-detail-note-label">{{ mode.detail_points_label | default: 'Research moves' }}</span>
                <ol class="home-motion-detail-notes">
                  {% for point in mode.detail_points %}
                    <li>
                      <span>0{{ forloop.index }}</span>
                      <p>{{ point }}</p>
                    </li>
                  {% endfor %}
                </ol>
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    {% endif %}
    {% if page.research_motion.exploring %}
      <div class="home-motion-exploring" aria-labelledby="{{ motion_section_id }}-exploring-title">
        <div class="home-motion-exploring-copy">
          <span>Exploring</span>
          <h3 id="{{ motion_section_id }}-exploring-title">{{ page.research_motion.exploring.title }}</h3>
          <p>{{ page.research_motion.exploring.intro }}</p>
        </div>
        {% if page.research_motion.exploring.items %}
          <div class="home-motion-exploring-list">
            {% for item in page.research_motion.exploring.items %}
              <span>
                <strong>{{ item.title }}</strong>
                <em>{{ item.text }}</em>
              </span>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </section>
{% endif %}
