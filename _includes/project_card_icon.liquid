{% assign project_icon = include.icon | default: '' %}
{% if project_icon != '' %}
  <svg
    class="project-card-icon project-card-icon--{{ project_icon | escape }}"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    focusable="false"
    data-project-card-icon="{{ project_icon | escape }}"
  >
    {% case project_icon %}
      {% when 'constellation' %}
        <circle cx="5" cy="15" r="1.6"/>
        <circle cx="11" cy="6" r="1.6"/>
        <circle cx="19" cy="10" r="1.6"/>
        <circle cx="16" cy="19" r="1.6"/>
        <path d="m6.2 13.8 3.7-6.4M12.6 6.8l4.8 2.4M18.4 11.4l-1.8 6M14.5 18.4l-8-2.8"/>
      {% when 'pulse' %}
        <path d="M3 12h4l2.1-5.2L13 17l2.4-5H21"/>
        <path d="M4 19h16M4 5h16" opacity=".38"/>
      {% when 'desk' %}
        <path d="M3 15h18M5 15v5M19 15v5"/>
        <rect x="7" y="4" width="10" height="7" rx="1.2"/>
        <path d="M12 11v4M9.5 15h5"/>
      {% when 'citation' %}
        <path d="M6 5h12M6 9h8M6 13h5M6 17h7"/>
        <circle cx="17" cy="16" r="3"/>
        <path d="m19.2 18.2 2 2"/>
      {% when 'receipt' %}
        <path d="M7 3h10a1 1 0 0 1 1 1v17l-3-2-3 2-3-2-3 2V4a1 1 0 0 1 1-1Z"/>
        <path d="M9 8h6M9 12h6M9 16h3"/>
      {% when 'expand' %}
        <rect x="4" y="5" width="16" height="14" rx="2"/>
        <path d="m9 14 6-6M11 8h4v4"/>
      {% when 'paw' %}
        <ellipse cx="12" cy="15.5" rx="4.2" ry="3.5"/>
        <circle cx="6.8" cy="11" r="1.5"/>
        <circle cx="10.2" cy="7.5" r="1.5"/>
        <circle cx="13.8" cy="7.5" r="1.5"/>
        <circle cx="17.2" cy="11" r="1.5"/>
      {% when 'archive' %}
        <path d="M4 7h16v13H4zM3 4h18v3H3z"/>
        <path d="M9 11h6"/>
      {% when 'spooder' %}
        <circle cx="12" cy="13" r="3"/>
        <circle cx="12" cy="8.5" r="2"/>
        <path d="m9 11-4-2M9 13H4m5.5 2.2L6 18m9-7 4-2m-4 4h5m-5.5 2.2L18 18"/>
      {% when 'wheel' %}
        <circle cx="12" cy="12" r="8"/>
        <circle cx="12" cy="12" r="2"/>
        <path d="M5 10h14M12 14v6M8 11l4 3 4-3"/>
    {% endcase %}
  </svg>
{% endif %}
