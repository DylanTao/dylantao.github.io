{% assign brand_initials = include.initials | default: 'ST' %}
<span class="site-brand-mark brand-orange" data-brand-orange data-brand-initials="{{ brand_initials | escape }}" aria-hidden="true">
  <span class="brand-orange-text-fallback">{{ brand_initials }}</span>
  <svg class="brand-orange-svg" viewBox="0 0 64 64" focusable="false" aria-hidden="true">
    <defs>
      <radialGradient id="brand-orange-body-gradient" cx="31%" cy="24%" r="72%">
        <stop class="brand-orange-stop-highlight" offset="0%"></stop>
        <stop class="brand-orange-stop-rind" offset="44%"></stop>
        <stop class="brand-orange-stop-deep" offset="100%"></stop>
      </radialGradient>
      <radialGradient id="brand-orange-highlight-gradient" cx="38%" cy="34%" r="62%">
        <stop class="brand-orange-stop-glint" offset="0%"></stop>
        <stop class="brand-orange-stop-glint-fade" offset="100%"></stop>
      </radialGradient>
    </defs>
    <g class="brand-orange-crown" data-brand-crown>
      <path class="brand-orange-stem" data-brand-stem d="M31.8 17.3C31.7 13.1 33.8 10.4 36.4 8.7"></path>
      <g class="brand-orange-leaves" data-brand-leaves>
        <path class="brand-orange-leaf brand-orange-leaf-a" d="M33.8 14.6C38.4 8.9 46.5 8.4 50.3 12.4C45.3 17.5 38.7 18.1 33.8 14.6Z"></path>
        <path class="brand-orange-leaf brand-orange-leaf-b" d="M31.1 15.5C26.9 10.5 21.1 10.6 17.9 14.1C22.7 18.3 27.6 18.6 31.1 15.5Z"></path>
      </g>
    </g>
    <g class="brand-orange-body-shell" data-brand-body-shell>
      <path class="brand-orange-body" data-brand-body d="M52.4 34.2C52.4 45.4 43.7 54.2 32.1 54.2C20.5 54.2 11.4 46.1 11.4 34.6C11.4 22.7 20.4 14.2 32.7 14.5C44.9 14.8 52.4 23.5 52.4 34.2Z"></path>
      <ellipse class="brand-orange-highlight" data-brand-highlight cx="24.8" cy="25.1" rx="8.2" ry="5.4" transform="rotate(-26 24.8 25.1)"></ellipse>
      <g class="brand-orange-pores" data-brand-pores>
        <circle class="brand-orange-pore" cx="22.6" cy="33.2" r="0.74"></circle>
        <circle class="brand-orange-pore" cx="28.7" cy="20.8" r="0.58"></circle>
        <circle class="brand-orange-pore" cx="38.2" cy="25.4" r="0.66"></circle>
        <circle class="brand-orange-pore" cx="42.4" cy="36.2" r="0.7"></circle>
        <circle class="brand-orange-pore" cx="26.1" cy="45.1" r="0.62"></circle>
        <circle class="brand-orange-pore" cx="35.7" cy="48.1" r="0.56"></circle>
      </g>
      <text class="brand-orange-initials" data-brand-initials-text x="32" y="37.6" text-anchor="middle" dominant-baseline="middle">{{ brand_initials }}</text>
    </g>
  </svg>
</span>
