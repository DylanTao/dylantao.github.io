---
layout: default
---
<div class="home-page">
  {% include home/story_rail.liquid %}
  {% include home/hero.liquid %}
  {% include home/thesis.liquid %}
  {% include home/why_now.liquid %}
  {% include home/research_motion.liquid %}
  {% include home/news_publications.liquid %}
  {% include home/recruiting.liquid %}

  {% if page.social %}
    <section id="connect" class="home-section home-social-section home-reveal" data-home-section="connect" aria-label="Contact and profiles">
      <div class="home-section-heading">
        <p class="home-kicker">Connect</p>
        <h2>Find me around the web.</h2>
      </div>
      {% include home/lineage.liquid %}
      <div class="social home-social">
        <div class="contact-icons">{% social_links %}</div>
        {% assign agentic_usage = site.data.agentic_usage %}
        {% if agentic_usage.total %}
          {% assign total_energy = agentic_usage.total.energy_equivalence %}
          <div
            class="home-agentic-tally"
            aria-label="Site revamp ledger: estimated Codex tokens and agent-hours, exact Git commit count, and estimated energy-equivalence"
          >
            <p class="home-agentic-kicker">
              <span class="home-agentic-kicker-copy">Build ledger · since {{ agentic_usage.total.since_label }}</span>
              <span class="home-agentic-info-wrap home-agentic-info-wrap-kicker">
                <button
                  type="button"
                  class="home-agentic-info"
                  aria-label="How the site-build usage totals are calculated"
                  aria-describedby="home-agentic-tooltip"
                >
                  i
                </button>
                <span id="home-agentic-tooltip" class="home-agentic-tooltip" role="tooltip">
                  <span class="home-agentic-tooltip-main">
                    Site-build tokens and agent-hours are estimated from retained Codex logs. The commit count is exact from this repository's Git
                    history. Energy is an estimated equivalence using a midpoint of {{ total_energy.wh_per_token_midpoint }} Wh per token, not
                    measured electricity use.
                  </span>
                </span>
              </span>
            </p>
            <dl class="home-agentic-grid">
              <div class="home-agentic-stat">
                <dt>{{ agentic_usage.total.tokens_label }}</dt>
                <dd>site-build tokens</dd>
              </div>
              <div class="home-agentic-stat">
                <dt>{{ agentic_usage.total.hours_label }}</dt>
                <dd>agent-hours</dd>
              </div>
              <div class="home-agentic-stat">
                <dt>{{ agentic_usage.total.commits }}</dt>
                <dd>site commits</dd>
              </div>
              {% if total_energy %}
                <div class="home-agentic-stat">
                  <dt>{{ total_energy.kwh_midpoint }}</dt>
                  <dd>est. kWh</dd>
                </div>
              {% endif %}
            </dl>
            {% assign account_lifetime = agentic_usage.account_lifetime %}
            {% assign all_github_commits = 0 %}
            {% for week in site.data.github_activity.weeks %}
              {% assign all_github_commits = all_github_commits | plus: week.commits %}
            {% endfor %}
            {% if account_lifetime and all_github_commits > 0 %}
              <a
                class="home-agentic-heartbeat"
                href="{{ '/github-activity/' | relative_url }}"
              >
                <span class="home-agentic-heartbeat-pulse" aria-hidden="true"></span>
                <span class="home-agentic-heartbeat-copy">
                  <strong>{{ account_lifetime.tokens_label }} Codex tokens</strong>
                  <small>{{ all_github_commits }} GitHub commits</small>
                </span>
                <svg
                  class="home-agentic-heartbeat-sparkline"
                  viewBox="0 0 112 28"
                  role="img"
                  aria-label="Last 30 calendar days of Codex token activity{% if account_lifetime.recent_activity.partial_last_day %}; {{ account_lifetime.recent_activity.end_label }} is partial{% endif %}"
                >
                  <polyline pathLength="1" points="{{ account_lifetime.recent_activity.sparkline_points }}"></polyline>
                </svg>
                <span class="home-agentic-heartbeat-route" aria-hidden="true">Follow the pulse →</span>
              </a>
            {% endif %}
          </div>
        {% endif %}
        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    </section>
  {% endif %}
</div>
