---
layout: default
---
{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

{% assign post_classes = 'post' %}
{% if page.collection == 'projects' %}
  {% assign post_classes = post_classes | append: ' project-detail' %}
  {% if page.hide_title %}
    {% assign post_classes = post_classes | append: ' project-case-page' %}
  {% endif %}
{% endif %}

<div class="{{ post_classes }}">
  {% unless page.hide_title %}
    <header class="post-header">
      <h1 class="post-title">{{ page.title }}</h1>
      <p class="post-description">{{ page.description }}</p>
    </header>
  {% endunless %}

  <article>
    {{ content }}
  </article>

  {% if page.related_publications %}
    <h2>References</h2>
    <div class="publications">
      {% bibliography --cited_in_order %}
    </div>
  {% endif %}

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
