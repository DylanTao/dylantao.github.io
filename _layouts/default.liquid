<!doctype html>
<html lang="{{ site.lang }}">
  <!-- Head -->
  <head>
    {% if page.redirect %}
      {% if page.redirect == true %}
        {% assign redirect = site.baseurl | append: '/' %}
      {% elsif page.redirect contains '://' %}
        {% assign redirect = page.redirect %}
      {% else %}
        {% assign redirect = page.redirect | relative_url %}
      {% endif %}
      <meta http-equiv="refresh" content="3; url={{ redirect }}">
    {% endif %}
    {% include head.liquid %}
  </head>

  <!-- Body -->
  <body class="{% if page.home_experience %}home-body{% endif %} {% if site.navbar_fixed %}fixed-top-nav{% endif %} {% unless site.footer_fixed %}sticky-bottom-footer{% endunless %}">
    <!-- Header -->
    {% include header.liquid %}

    <!-- Content -->
    {% assign main_container_class = 'container' %}
    {% assign main_container_spacing_class = 'mt-5' %}
    {% if page.panel_wide or page.layout == 'post' or page.collection == 'projects' %}
      {% assign main_container_class = 'container panel-shell' %}
    {% endif %}
    {% if page.wide_layout %}
      {% assign main_container_class = 'container-fluid px-3 px-md-4 px-xl-5' %}
      {% assign main_container_spacing_class = 'mt-3 mt-md-4' %}
    {% endif %}
    {% assign toc_sidebar_class = 'col-sm-3' %}
    {% assign toc_main_class = 'col-sm-9' %}
    {% if page.layout == 'cv' %}
      {% assign toc_sidebar_class = 'col-md-3 col-lg-2' %}
      {% assign toc_main_class = 'col-md-9 col-lg-10' %}
    {% endif %}
    <div class="{{ main_container_class }} {{ main_container_spacing_class }}" role="main">
      {% if page.toc and page.toc.sidebar %}
        {% if page.toc.sidebar == 'right' %}
          <div class="row toc-layout toc-layout-right">
            <!-- main content area -->
            <div class="{{ toc_main_class }} toc-main-column">{{ content }}</div>
            <!-- sidebar, which will move to the top on a small screen -->
            <div class="{{ toc_sidebar_class }} toc-sidebar-column">
              <nav id="toc-sidebar" class="sticky-top" aria-label="On this page navigation"></nav>
            </div>
          </div>
        {% else %}
          <div class="row toc-layout toc-layout-left">
            <!-- sidebar, which will move to the top on a small screen -->
            <div class="{{ toc_sidebar_class }} toc-sidebar-column">
              <nav id="toc-sidebar" class="sticky-top" aria-label="On this page navigation"></nav>
            </div>
            <!-- main content area -->
            <div class="{{ toc_main_class }} toc-main-column">{{ content }}</div>
          </div>
        {% endif %}
      {% else %}
        {{ content }}
      {% endif %}
    </div>

    <!-- Footer -->
    {% include footer.liquid %}

    <!-- JavaScripts -->
    {% include scripts.liquid %}
  </body>
</html>
