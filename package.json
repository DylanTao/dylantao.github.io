{
  "scripts": {
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint:prettier": "prettier . --check",
    "lint:style-contract": "node test/style_contract.js",
    "test:visual": "npm run test:visual:public && npm run test:visual:legacy",
    "test:visual:public": "npm run test:visual:site && npm run test:visual:scene",
    "test:visual:site": "playwright test --config test/visual/public.config.js --output=test-results/public-visual-site sitewide.spec.js paper-constellation.spec.js",
    "test:visual:scene": "playwright test --config test/visual/public.config.js --output=test-results/public-visual-scene desk-scene.spec.js",
    "test:visual:legacy": "playwright test --config test/visual/playwright.config.js",
    "test:visual:update": "npm run test:visual:legacy:update",
    "test:visual:legacy:update": "playwright test --config test/visual/playwright.config.js --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@shopify/prettier-plugin-liquid": "1.10.2",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "3.8.3"
  }
}
